# ── Base de datos ──────────────────────────────────────────
# Railway te da esta URL automáticamente al agregar PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ── Mercado Libre ───────────────────────────────────────────
# Obtenés esto en developers.mercadolibre.com.ar
ML_CLIENT_ID="TU_CLIENT_ID"
ML_CLIENT_SECRET="TU_CLIENT_SECRET"
ML_ACCESS_TOKEN="TU_ACCESS_TOKEN"
# El refresh token para renovar el access token automáticamente
ML_REFRESH_TOKEN="TU_REFRESH_TOKEN"

# ── WooCommerce (abctechos.com) ─────────────────────────────
# Se genera en WooCommerce > Ajustes > Avanzado > Webhooks
WC_WEBHOOK_SECRET="TU_WEBHOOK_SECRET_WOOCOMMERCE"

# ── Tiendanube (acerosinoxidables.com.ar) ───────────────────
TN_APP_ID="TU_APP_ID"
TN_CLIENT_SECRET="TU_CLIENT_SECRET_TIENDANUBE"

# ── Tango Factura ───────────────────────────────────────────
TANGO_API_URL="https://api.tangofactura.com"
TANGO_API_TOKEN="TU_TOKEN_TANGO"
TANGO_PTO_VTA="1"
TANGO_TIPO_COMP="REM"

# ── Notificaciones WhatsApp (opcional por ahora) ────────────
# Registrarse en twilio.com para obtener estos datos
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="+14155238886"

# ── Redis (opcional — para cola de tareas) ──────────────────
# Railway también provee Redis con un click
REDIS_URL=""

# ── Servidor ────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# ── Seguridad ───────────────────────────────────────────────
# Orígenes permitidos para CORS (tu panel logístico)
ALLOWED_ORIGINS="https://tu-panel.railway.app,https://abctechos.com"
